<resources>
    <!-- Usamos un tema ligero sin ActionBar; la UI real se maneja en Compose -->
    <style name="Theme.LapMaster" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.LapMaster.Splash" parent="Theme.LapMaster">
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
    </style>
</resources>
